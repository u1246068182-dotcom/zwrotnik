---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";

export const prerender = false;

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

// RLS: zapytanie zwróci pozycję tylko, gdy należy do zalogowanego użytkownika.
// Brak (nie istnieje lub cudza) → renderujemy stan „nie znaleziono", nie ujawniając danych.
const { data: item } = supabase
  ? await supabase
      .from("items")
      .select("*")
      .eq("id", id ?? "")
      .maybeSingle()
  : { data: null };

const error = Astro.url.searchParams.get("error");
const typy: { value: string; label: string }[] = [
  { value: "zwrot", label: "Zwrot (14 dni)" },
  { value: "rekojmia", label: "Rękojmia (2 lata)" },
  { value: "subskrypcja", label: "Subskrypcja (data odnowienia)" },
  { value: "wlasny", label: "Własny termin (konkretna data)" },
];
---

<Layout title="Edycja pozycji — Zwrotnik">
  <main class="mx-auto max-w-2xl p-4 sm:p-6">
    <header class="mb-6">
      <h1 class="text-2xl font-bold">Edycja pozycji</h1>
      <a href="/dashboard" class="text-muted-foreground text-sm hover:underline">← Wróć do listy</a>
    </header>

    {
      error && (
        <p class="mb-4 rounded-lg border border-red-400/40 bg-red-500/10 p-3 text-sm text-red-600 dark:text-red-300">
          {error}
        </p>
      )
    }

    {
      !item ? (
        <div class="text-muted-foreground rounded-xl border border-dashed p-8 text-center">
          <p class="font-medium">Nie znaleziono pozycji.</p>
          <p class="text-sm">Mogła zostać usunięta albo nie należy do Ciebie.</p>
          <a href="/dashboard" class="text-foreground mt-3 inline-block text-sm underline">
            Wróć do listy
          </a>
        </div>
      ) : (
        <form method="POST" action={`/api/items/${item.id}`} class="grid gap-3 rounded-xl border p-4 sm:grid-cols-2">
          <input type="hidden" name="_action" value="update" />
          <label class="flex flex-col text-sm sm:col-span-2">
            Nazwa
            <input name="nazwa" required value={item.nazwa} class="mt-1 rounded-lg border bg-transparent px-3 py-2" />
          </label>
          <label class="flex flex-col text-sm">
            Sklep (opcjonalnie)
            <input name="sklep" value={item.sklep ?? ""} class="mt-1 rounded-lg border bg-transparent px-3 py-2" />
          </label>
          <label class="flex flex-col text-sm">
            Kwota (zł)
            <input
              name="kwota"
              type="number"
              step="0.01"
              min="0.01"
              required
              value={item.kwota}
              class="mt-1 rounded-lg border bg-transparent px-3 py-2"
            />
          </label>
          <label class="flex flex-col text-sm">
            Data zakupu / odnowienia
            <input
              name="data_odniesienia"
              type="date"
              required
              value={item.data_odniesienia}
              class="mt-1 rounded-lg border bg-transparent px-3 py-2"
            />
          </label>
          <label class="flex flex-col text-sm">
            Typ okna
            <select name="typ_okna" required class="mt-1 rounded-lg border bg-transparent px-3 py-2">
              {typy.map((t) => (
                <option value={t.value} selected={t.value === item.typ_okna}>
                  {t.label}
                </option>
              ))}
            </select>
          </label>
          <div class="flex gap-3 sm:col-span-2">
            <button
              type="submit"
              class="bg-primary text-primary-foreground hover:bg-primary/90 rounded-lg px-4 py-2 font-medium"
            >
              Zapisz zmiany
            </button>
            <a href="/dashboard" class="hover:bg-muted rounded-lg border px-4 py-2 font-medium">
              {" "}
              Anuluj{" "}
            </a>
          </div>
        </form>
      )
    }
  </main>
</Layout>
