---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listActiveForUser, listDoneForUser } from "@/lib/services/items";
import { buildUrgencyView } from "@/lib/urgency";
import { formatReminderWarsaw } from "@/lib/reminders";
import type { UrgencyStatus } from "@/types";

const HOURS = Array.from({ length: 24 }, (_, h) => h);

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const items = supabase ? await listActiveForUser(supabase) : [];
const doneItems = supabase ? await listDoneForUser(supabase) : [];
const view = buildUrgencyView(items, new Date());
const error = Astro.url.searchParams.get("error");

const BUCKETS: { key: UrgencyStatus; label: string; tone: string }[] = [
  { key: "pilne", label: "🔴 Pilne", tone: "border-red-400/40" },
  { key: "wkrotce", label: "🟡 Wkrótce", tone: "border-amber-400/40" },
  { key: "spokojnie", label: "🟢 Spokojnie", tone: "border-emerald-400/40" },
  { key: "minelo", label: "⚪ Minęło", tone: "border-white/15" },
];

function fmtPln(n: number): string {
  return n.toLocaleString("pl-PL", { style: "currency", currency: "PLN" });
}
function dniLabel(d: number): string {
  if (d < 0) return `${Math.abs(d)} dni temu`;
  if (d === 0) return "dziś";
  if (d === 1) return "jutro";
  return `za ${d} dni`;
}
const isEmpty = items.length === 0;
---

<Layout title="Zwrotnik">
  <main class="mx-auto max-w-2xl p-4 sm:p-6">
    <header class="mb-6 flex items-center justify-between gap-4">
      <div>
        <a href="/" class="text-2xl font-bold hover:underline">Zwrotnik</a>
        <p class="text-sm text-gray-500">{user?.email}</p>
      </div>
      <form method="POST" action="/api/auth/signout">
        <button type="submit" class="rounded-lg border px-3 py-1.5 text-sm hover:bg-gray-100">Wyloguj</button>
      </form>
    </header>

    <div class="mb-6 rounded-xl border bg-gray-50 p-4">
      <span class="text-sm text-gray-500">Zagrożone</span>
      <p class="text-3xl font-bold">{fmtPln(view.sumaZagrozona)}</p>
    </div>

    {error && <p class="mb-4 rounded-lg border border-red-300 bg-red-50 p-3 text-sm text-red-700">{error}</p>}

    <form method="POST" action="/api/items" class="mb-8 grid gap-3 rounded-xl border p-4 sm:grid-cols-2">
      <label class="flex flex-col text-sm sm:col-span-2">
        Nazwa
        <input name="nazwa" required class="mt-1 rounded-lg border px-3 py-2" placeholder="np. Słuchawki Sony" />
      </label>
      <label class="flex flex-col text-sm">
        Sklep (opcjonalnie)
        <input name="sklep" class="mt-1 rounded-lg border px-3 py-2" placeholder="np. Media Expert" />
      </label>
      <label class="flex flex-col text-sm">
        Kwota (zł)
        <input name="kwota" type="number" step="0.01" min="0.01" required class="mt-1 rounded-lg border px-3 py-2" />
      </label>
      <label class="flex flex-col text-sm">
        Data zakupu / odnowienia
        <input name="data_odniesienia" type="date" required class="mt-1 rounded-lg border px-3 py-2" />
      </label>
      <label class="flex flex-col text-sm">
        Typ okna
        <select name="typ_okna" required class="mt-1 rounded-lg border px-3 py-2">
          <option value="zwrot">Zwrot (14 dni)</option>
          <option value="rekojmia">Rękojmia (2 lata)</option>
          <option value="subskrypcja">Subskrypcja (data odnowienia)</option>
          <option value="wlasny">Własny termin (konkretna data)</option>
        </select>
      </label>
      <button
        type="submit"
        class="rounded-lg bg-gray-900 px-4 py-2 font-medium text-white hover:bg-gray-700 sm:col-span-2"
      >
        Dodaj pozycję
      </button>
    </form>

    {
      isEmpty ? (
        <div class="rounded-xl border border-dashed p-8 text-center text-gray-500">
          <p class="font-medium">Brak pozycji.</p>
          <p class="text-sm">Dodaj pierwszy zakup powyżej, a zobaczysz, ile dni i złotych jest zagrożonych.</p>
        </div>
      ) : (
        <div class="space-y-6">
          {BUCKETS.filter((b) => view.buckets[b.key].length > 0).map((b) => (
            <section>
              <h2 class="mb-2 text-sm font-semibold text-gray-600">{b.label}</h2>
              <ul class="space-y-2">
                {view.buckets[b.key].map((it) => (
                  <li class:list={`flex flex-col gap-2 rounded-lg border-l-4 bg-white p-3 shadow-sm ${b.tone}`}>
                    <div class="flex items-center justify-between gap-3">
                      <div class="min-w-0">
                        <p class="truncate font-medium">{it.nazwa}</p>
                        <p class="text-xs text-gray-500">
                          {it.sklep ?? "—"} · {dniLabel(it.dniDoZamkniecia)}
                        </p>
                      </div>
                      <div class="flex shrink-0 items-center gap-2">
                        <span class="font-semibold">{fmtPln(it.kwota)}</span>
                        <a
                          href={`/items/${it.id}/edit`}
                          class="rounded-md border px-2 py-1 text-xs hover:bg-gray-100"
                          aria-label="Edytuj"
                        >
                          Edytuj
                        </a>
                        <form method="POST" action={`/api/items/${it.id}`}>
                          <input type="hidden" name="_action" value="done" />
                          <button
                            type="submit"
                            class="rounded-md border px-2 py-1 text-xs hover:bg-emerald-50"
                            aria-label="Oznacz jako załatwione"
                          >
                            Załatwione
                          </button>
                        </form>
                        <form
                          method="POST"
                          action={`/api/items/${it.id}`}
                          onsubmit="return confirm('Usunąć pozycję? Tej operacji nie można cofnąć.')"
                        >
                          <input type="hidden" name="_action" value="delete" />
                          <button
                            type="submit"
                            class="rounded-md border px-2 py-1 text-xs text-red-600 hover:bg-red-50"
                            aria-label="Usuń"
                          >
                            Usuń
                          </button>
                        </form>
                      </div>
                    </div>
                    <div class="border-t border-gray-100 pt-2 text-xs text-gray-600">
                      {it.reminder_at ? (
                        <div class="flex items-center justify-between gap-2">
                          <span>🔔 Przypomnienie: {formatReminderWarsaw(it.reminder_at)}</span>
                          <form method="POST" action={`/api/items/${it.id}`}>
                            <input type="hidden" name="_action" value="clear-reminder" />
                            <button type="submit" class="rounded-md border px-2 py-1 hover:bg-gray-100">
                              Usuń przypomnienie
                            </button>
                          </form>
                        </div>
                      ) : (
                        <form method="POST" action={`/api/items/${it.id}`} class="flex flex-wrap items-center gap-2">
                          <input type="hidden" name="_action" value="set-reminder" />
                          <span>🔔 Przypomnij mailem:</span>
                          <input type="date" name="reminder_date" required class="rounded border px-2 py-1" />
                          <select name="reminder_hour" required class="rounded border px-1 py-1">
                            {HOURS.map((h) => (
                              <option value={h}>{`${String(h).padStart(2, "0")}:00`}</option>
                            ))}
                          </select>
                          <button type="submit" class="rounded-md border px-2 py-1 hover:bg-gray-100">
                            Ustaw
                          </button>
                        </form>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )
    }

    {
      doneItems.length > 0 && (
        <section class="mt-8">
          <h2 class="mb-2 text-sm font-semibold text-gray-600">✅ Załatwione ({doneItems.length})</h2>
          <ul class="space-y-2">
            {doneItems.map((it) => (
              <li class="flex items-center justify-between gap-3 rounded-lg border bg-gray-50 p-3 text-gray-500">
                <div class="min-w-0">
                  <p class="truncate font-medium line-through">{it.nazwa}</p>
                  <p class="text-xs">{it.sklep ?? "—"}</p>
                </div>
                <div class="flex shrink-0 items-center gap-2">
                  <span class="font-semibold">{fmtPln(it.kwota)}</span>
                  <form method="POST" action={`/api/items/${it.id}`}>
                    <input type="hidden" name="_action" value="undone" />
                    <button
                      type="submit"
                      class="rounded-md border px-2 py-1 text-xs hover:bg-white"
                      aria-label="Przywróć"
                    >
                      Przywróć
                    </button>
                  </form>
                  <form
                    method="POST"
                    action={`/api/items/${it.id}`}
                    onsubmit="return confirm('Usunąć pozycję? Tej operacji nie można cofnąć.')"
                  >
                    <input type="hidden" name="_action" value="delete" />
                    <button
                      type="submit"
                      class="rounded-md border px-2 py-1 text-xs text-red-600 hover:bg-red-50"
                      aria-label="Usuń"
                    >
                      Usuń
                    </button>
                  </form>
                </div>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</Layout>
