---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

// Strona pomocnicza (rejestracja idzie przez /auth/verify z kodem OTP).
const content = {
  emoji: "✅",
  heading: "Konto utworzone",
  description: "Twoje konto jest aktywne. Możesz się zalogować.",
  linkText: "Przejdź do logowania",
};
---

<Layout title={content.heading}>
  <div class="dark:bg-cosmic relative flex min-h-screen items-center justify-center bg-slate-100 p-4">
    <div class="absolute top-4 right-4"><ThemeToggle /></div>
    <div
      class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white/80 p-8 text-center text-slate-900 backdrop-blur-xl dark:border-white/10 dark:bg-white/10 dark:text-white"
    >
      <div class="mb-4 text-5xl">{content.emoji}</div>
      <h1
        class="mb-3 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-2xl font-bold text-transparent dark:from-blue-200 dark:to-purple-200"
      >
        {content.heading}
      </h1>
      <p class="mb-6 text-slate-600 dark:text-blue-100/80">{content.description}</p>
      <a href="/auth/signin" class="text-sm text-purple-600 hover:underline dark:text-purple-300">
        {content.linkText}
      </a>
    </div>
  </div>
</Layout>
