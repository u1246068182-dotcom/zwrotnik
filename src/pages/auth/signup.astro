---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign up">
  <div class="dark:bg-cosmic relative flex min-h-screen items-center justify-center bg-slate-100 p-4">
    <div class="absolute top-4 right-4"><ThemeToggle /></div>
    <div
      class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white/80 p-8 text-slate-900 backdrop-blur-xl dark:border-white/10 dark:bg-white/10 dark:text-white"
    >
      <h1
        class="mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-center text-2xl font-bold text-transparent dark:from-blue-200 dark:to-purple-200"
      >
        Sign up
      </h1>
      <SignUpForm serverError={error} client:load />
      <p class="mt-4 text-center text-sm text-slate-600 dark:text-blue-100/60">
        Already have an account?{" "}
        <a href="/auth/signin" class="text-purple-600 hover:underline dark:text-purple-300"> Sign in </a>
      </p>
    </div>
  </div>
</Layout>
