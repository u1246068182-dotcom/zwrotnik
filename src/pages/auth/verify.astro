---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

export const prerender = false;

const email = Astro.url.searchParams.get("email")?.trim() ?? "";
const error = Astro.url.searchParams.get("error");
---

<Layout title="Potwierdź konto — Zwrotnik">
  <div class="dark:bg-cosmic relative flex min-h-screen items-center justify-center bg-slate-100 p-4">
    <div class="absolute top-4 right-4"><ThemeToggle /></div>
    <div
      class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white/80 p-8 text-slate-900 backdrop-blur-xl dark:border-white/10 dark:bg-white/10 dark:text-white"
    >
      <h1
        class="mb-2 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-center text-2xl font-bold text-transparent dark:from-blue-200 dark:to-purple-200"
      >
        Potwierdź konto
      </h1>

      {
        !email ? (
          <div class="text-center text-sm text-slate-600 dark:text-blue-100/70">
            <p class="mb-4">Brak adresu e-mail do potwierdzenia.</p>
            <a href="/auth/signup" class="text-purple-600 hover:underline dark:text-purple-300">
              Wróć do rejestracji
            </a>
          </div>
        ) : (
          <>
            <p class="mb-6 text-center text-sm text-slate-600 dark:text-blue-100/70">
              Wpisz kod, który wysłaliśmy na <span class="text-slate-900 dark:text-white">{email}</span>.
            </p>

            {error && (
              <p class="mb-4 rounded-lg border border-red-400/40 bg-red-500/10 p-3 text-center text-sm text-red-700 dark:border-red-300/40 dark:bg-red-500/15 dark:text-red-100">
                {error}
              </p>
            )}

            <form method="POST" action="/api/auth/verify" class="space-y-4">
              <input type="hidden" name="email" value={email} />
              <input
                id="otp-input"
                name="token"
                inputmode="numeric"
                autocomplete="one-time-code"
                required
                placeholder="000000"
                aria-label="Kod z e-maila"
                class="w-full rounded-lg border border-slate-300 bg-white/70 px-3 py-3 text-center text-2xl tracking-[0.4em] text-slate-900 placeholder-slate-400 focus:border-purple-400 focus:outline-none dark:border-white/20 dark:bg-white/5 dark:text-white dark:placeholder-white/30"
              />
              <button
                type="submit"
                class="w-full rounded-lg bg-purple-600 px-4 py-3 font-medium text-white transition-colors hover:bg-purple-500"
              >
                Potwierdź
              </button>
            </form>

            <p class="mt-4 text-center text-xs text-slate-500 dark:text-blue-100/50">
              Nie masz kodu?{" "}
              <a href="/auth/signup" class="text-purple-600 hover:underline dark:text-purple-300">
                Zarejestruj się ponownie
              </a>
            </p>
          </>
        )
      }
    </div>
  </div>
</Layout>

<script is:inline>
  // Wklejony z maila kod bywa ze spacjami/rozstrzelony — czyścimy do samych cyfr (max 6).
  const otp = document.getElementById("otp-input");
  if (otp) {
    otp.addEventListener("input", () => {
      otp.value = otp.value.replace(/\D/g, "").slice(0, 8);
    });
  }
</script>
