---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error");
const registered = Astro.url.searchParams.get("registered") === "1";
const confirmed = Astro.url.searchParams.get("confirmed") === "1";
const exists = Astro.url.searchParams.get("exists") === "1";
---

<Layout title="Sign in">
  <div class="dark:bg-cosmic relative flex min-h-screen items-center justify-center bg-slate-100 p-4">
    <div class="absolute top-4 right-4"><ThemeToggle /></div>
    <div
      class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white/80 p-8 text-slate-900 backdrop-blur-xl dark:border-white/10 dark:bg-white/10 dark:text-white"
    >
      <h1
        class="mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-center text-2xl font-bold text-transparent dark:from-blue-200 dark:to-purple-200"
      >
        Sign in
      </h1>
      {
        (registered || confirmed) && (
          <p class="mb-4 rounded-lg border border-emerald-300/40 bg-emerald-500/15 p-3 text-center text-sm text-emerald-100">
            {confirmed ? "Konto potwierdzone — zaloguj się." : "Konto utworzone — zaloguj się."}
          </p>
        )
      }
      {
        exists && (
          <p class="mb-4 rounded-lg border border-amber-300/40 bg-amber-500/15 p-3 text-center text-sm text-amber-100">
            To konto już istnieje — zaloguj się poniżej.
          </p>
        )
      }
      <SignInForm serverError={error} client:load />
      <p class="mt-4 text-center text-sm text-slate-600 dark:text-blue-100/60">
        Don't have an account? <a href="/auth/signup" class="text-purple-300 hover:underline">Sign up</a>
      </p>
    </div>
  </div>
</Layout>
