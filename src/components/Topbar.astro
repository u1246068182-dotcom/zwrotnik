---
import ThemeToggle from "@/components/ThemeToggle.astro";
const { user } = Astro.locals;
---

<div
  class="mb-4 flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white/70 px-4 py-2 text-sm text-slate-700 dark:border-white/10 dark:bg-white/5 dark:text-white/80"
>
  {
    user ? (
      <>
        <span class="truncate text-slate-500 dark:text-blue-100/70">{user.email}</span>
        <div class="flex shrink-0 items-center gap-3">
          <ThemeToggle />
          <a
            href="/dashboard"
            class="text-purple-600 transition-colors hover:text-purple-500 hover:underline dark:text-purple-300 dark:hover:text-purple-100"
          >
            Panel
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="text-purple-600 transition-colors hover:text-purple-500 hover:underline dark:text-purple-300 dark:hover:text-purple-100"
            >
              Wyloguj
            </button>
          </form>
        </div>
      </>
    ) : (
      <>
        <span class="text-slate-500 dark:text-blue-100/70">Niezalogowany</span>
        <div class="flex shrink-0 items-center gap-3">
          <ThemeToggle />
          <a
            href="/auth/signin"
            class="text-purple-600 transition-colors hover:text-purple-500 hover:underline dark:text-purple-300 dark:hover:text-purple-100"
          >
            Zaloguj
          </a>
          <a
            href="/auth/signup"
            class="text-purple-600 transition-colors hover:text-purple-500 hover:underline dark:text-purple-300 dark:hover:text-purple-100"
          >
            Załóż konto
          </a>
        </div>
      </>
    )
  }
</div>
