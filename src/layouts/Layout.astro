---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";

interface Props {
  title?: string;
}

const { title = "Zwrotnik" } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    {/* Motyw: ciemny domyślnie; jasny gdy użytkownik wybrał. Bez migotania (przed renderem). */}
    <script is:inline>
      if (localStorage.getItem("theme") !== "light") document.documentElement.classList.add("dark");
    </script>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Uwaga:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Dokumentacja"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
